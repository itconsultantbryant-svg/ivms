# Optional. Use SQLite for local dev (no Postgres). On Render, omit this and set DATABASE_URL.
# USE_SQLITE=1

# Render provides this when you attach a PostgreSQL database.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Optional. Frontend origin for CORS (e.g. https://your-app.onrender.com).
# FRONTEND_URL=

# Optional. Set to false to disable SSL for Postgres (e.g. local).
# DATABASE_SSL=false
